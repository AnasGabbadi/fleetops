<div class="maintenance-details-container">
  {{#if this.maintenance}}
    <div class="details-header">
      <div>
        <h1>{{this.maintenance.publicId}}</h1>
        <p class="breadcrumb">
          <a href="#" {{on "click" this.back}}>Maintenances</a> / Détails
        </p>
      </div>
      <button class="btn btn-secondary" {{on "click" this.back}}>← Retour</button>
    </div>

    <div class="status-bar">
      <span class="badge {{this.maintenance.statusBadgeClass}}">{{this.maintenance.statusLabel}}</span>
      <span class="badge {{this.maintenance.paymentBadgeClass}}">{{this.maintenance.paymentStatusLabel}}</span>
      <span class="badge {{this.maintenance.priorityBadgeClass}}">{{this.maintenance.priorityLabel}}</span>
    </div>

    <div class="details-grid">
      <div class="details-card">
        <h3>🚗 Véhicule</h3>
        <p><strong>Véhicule:</strong> {{this.maintenance.vehicleUuid}}</p>
        <p><strong>Type:</strong> {{this.maintenance.maintenanceType}}</p>
        <p><strong>Ville:</strong> {{this.maintenance.city}}</p>
      </div>

      <div class="details-card">
        <h3>🏢 Garage & Créneau</h3>
        {{#if this.garage}}
          <p><strong>Garage:</strong> {{this.garage.name}}</p>
        {{/if}}
        {{#if this.appointmentSlot}}
          <p><strong>Date:</strong> {{format-date this.appointmentSlot.date "dd/MM/yyyy"}}</p>
          <p><strong>Heure:</strong> {{this.appointmentSlot.time}}</p>
        {{/if}}
      </div>

      <div class="details-card">
        <h3>📦 Produits ({{this.items.length}})</h3>
        {{#each this.items as |item|}}
          <div class="item-line">
            <span>{{item.productName}} (x{{item.quantity}})</span>
            <strong>{{item.totalPriceMad}} MAD</strong>
          </div>
        {{/each}}
      </div>

      <div class="details-card highlight">
        <h3>💰 Résumé des Coûts</h3>
        <div class="cost-line">
          <span>Produits:</span>
          <strong>{{this.costBreakdown.productsCost}} MAD</strong>
        </div>
        <div class="cost-line">
          <span>Service:</span>
          <strong>{{this.costBreakdown.serviceCost}} MAD</strong>
        </div>
        <div class="cost-line">
          <span>TVA:</span>
          <strong>{{this.costBreakdown.tax}} MAD</strong>
        </div>
        {{#if this.costBreakdown.discount}}
          <div class="cost-line discount">
            <span>Remise:</span>
            <strong>-{{this.costBreakdown.discount}} MAD</strong>
          </div>
        {{/if}}
        <div class="cost-line total">
          <span>TOTAL:</span>
          <strong>{{this.costBreakdown.total}} MAD</strong>
        </div>
      </div>
    </div>

    {{#if this.maintenance.customerMessage}}
      <div class="details-card full-width">
        <h3>📝 Notes Client</h3>
        <p>{{this.maintenance.customerMessage}}</p>
      </div>
    {{/if}}

    <div class="actions-bar">
      {{#if this.canEdit}}
        <button class="btn btn-info" {{on "click" this.edit}}>✏️ Éditer</button>
      {{/if}}

      {{#if this.canConfirm}}
        <button class="btn btn-success" {{on "click" this.confirmMaintenance}} disabled={{this.isUpdating}}>
          ✓ Confirmer
        </button>
      {{/if}}

      {{#if this.canStart}}
        <button class="btn btn-primary" {{on "click" this.startMaintenance}} disabled={{this.isUpdating}}>
          ▶️ Démarrer
        </button>
      {{/if}}

      {{#if this.canComplete}}
        <button class="btn btn-success" {{on "click" this.completeMaintenance}} disabled={{this.isUpdating}}>
          ✓ Terminer
        </button>
      {{/if}}

      {{#if this.canPay}}
        <button class="btn btn-warning" {{on "click" this.markAsPaid}} disabled={{this.isUpdating}}>
          💳 Marquer comme payée
        </button>
      {{/if}}

      {{#if this.canCancel}}
        <button class="btn btn-danger" {{on "click" this.cancelMaintenance}} disabled={{this.isUpdating}}>
          ✕ Annuler
        </button>
      {{/if}}
    </div>
  {{else}}
    <div class="loading">
      <p>Chargement des détails...</p>
    </div>
  {{/if}}
</div>

<style>
  .maintenance-details-container { padding: 20px; }
  .details-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px; }
  .breadcrumb { margin: 5px 0 0 0; color: #666; }
  .breadcrumb a { color: #007bff; text-decoration: none; }
  .status-bar { display: flex; gap: 10px; margin-bottom: 20px; }
  .details-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 20px; margin-bottom: 20px; }
  .details-card { background: #fff; padding: 20px; border-radius: 8px; box-shadow: 0 2px 8px rgba(0,0,0,0.1); }
  .details-card.highlight { background: linear-gradient(135deg, #fff9e6 0%, #ffe6cc 100%); border-left: 4px solid #ffc107; }
  .details-card.full-width { grid-column: 1 / -1; }
  .details-card h3 { margin-top: 0; }
  .details-card p { margin: 8px 0; }
  .item-line, .cost-line { display: flex; justify-content: space-between; padding: 8px 0; border-bottom: 1px solid #eee; }
  .cost-line.discount { color: #28a745; }
  .cost-line.total { border-top: 2px solid #333; font-weight: bold; font-size: 18px; margin-top: 10px; }
  .actions-bar { display: flex; gap: 10px; flex-wrap: wrap; margin-top: 30px; }
  .badge { display: inline-block; padding: 8px 12px; border-radius: 4px; font-weight: bold; font-size: 12px; }
  .btn { padding: 10px 20px; border: none; border-radius: 4px; font-weight: bold; cursor: pointer; }
  .btn-primary { background: #007bff; color: #fff; }
  .btn-success { background: #28a745; color: #fff; }
  .btn-warning { background: #ffc107; color: #333; }
  .btn-danger { background: #dc3545; color: #fff; }
  .btn-info { background: #17a2b8; color: #fff; }
  .btn-secondary { background: #6c757d; color: #fff; }
  .btn:hover:not(:disabled) { opacity: 0.9; }
  .btn:disabled { opacity: 0.5; cursor: not-allowed; }
</style>
