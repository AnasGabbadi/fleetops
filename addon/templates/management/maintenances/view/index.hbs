<div class="flex flex-col gap-6 p-6 bg-gray-50 dark:bg-gray-900 h-full overflow-y-auto scrollable">
    {{#if @model}}
    <!-- Header -->
    <div class="flex items-center justify-between bg-white dark:bg-gray-800 p-6 rounded-lg shadow-sm border border-gray-200 dark:border-gray-700">
      <div>
        <h1 class="text-3xl font-bold text-gray-900 dark:text-white">{{@model.publicId}}</h1>
        <p class="text-sm text-gray-600 dark:text-gray-400 mt-2">
          <a href="#" {{on "click" this.back}} class="text-blue-600 dark:text-blue-400 hover:underline">Maintenances</a>
          <span class="mx-2">/</span>
          <span>Détails</span>
        </p>
      </div>
      <button class="px-4 py-2 bg-gray-600 dark:bg-gray-700 hover:bg-gray-700 dark:hover:bg-gray-600 text-white rounded text-sm font-medium transition" {{on "click" this.back}}>
        ← Retour
      </button>
    </div>

    <!-- Status Badges -->
    <div class="flex gap-2 flex-wrap">
      <span class="px-3 py-1 bg-yellow-100 dark:bg-yellow-900 text-yellow-800 dark:text-yellow-200 rounded text-xs font-semibold uppercase">{{@model.status}}</span>
      <span class="px-3 py-1 bg-red-100 dark:bg-red-900 text-red-800 dark:text-red-200 rounded text-xs font-semibold uppercase">{{@model.paymentStatus}}</span>
      <span class="px-3 py-1 bg-blue-100 dark:bg-blue-900 text-blue-800 dark:text-blue-200 rounded text-xs font-semibold uppercase">{{@model.priority}}</span>
    </div>

    <!-- Section: Prestation -->
    <div class="bg-white dark:bg-gray-800 rounded-lg shadow-sm border border-gray-200 dark:border-gray-700">
      <div class="px-6 py-4 border-b border-gray-200 dark:border-gray-700">
        <h2 class="text-lg font-semibold text-gray-900 dark:text-white">Prestation</h2>
      </div>
      <div class="px-6 py-4">
        <div class="grid grid-cols-2 gap-6">
          <div>
            <label class="block text-xs font-semibold text-gray-600 dark:text-gray-400 uppercase tracking-wide mb-2">Référence</label>
            <div class="text-sm text-gray-900 dark:text-white">{{@model.publicId}}</div>
          </div>
          <div>
            <label class="block text-xs font-semibold text-gray-600 dark:text-gray-400 uppercase tracking-wide mb-2">Statut</label>
            <span class="inline-block px-3 py-1 bg-yellow-100 dark:bg-yellow-900 text-yellow-800 dark:text-yellow-200 rounded text-xs font-semibold">{{@model.status}}</span>
          </div>
          <div>
            <label class="block text-xs font-semibold text-gray-600 dark:text-gray-400 uppercase tracking-wide mb-2">Type de prestation</label>
            <div class="text-sm text-gray-900 dark:text-white">{{@model.maintenanceType}}</div>
          </div>
          <div>
            <label class="block text-xs font-semibold text-gray-600 dark:text-gray-400 uppercase tracking-wide mb-2">Ville</label>
            <div class="text-sm text-gray-900 dark:text-white">{{@model.city}}</div>
          </div>
        </div>
      </div>
    </div>

    <!-- Section: Garage & Créneau -->
    <div class="bg-white dark:bg-gray-800 rounded-lg shadow-sm border border-gray-200 dark:border-gray-700">
      <div class="px-6 py-4 border-b border-gray-200 dark:border-gray-700">
        <h2 class="text-lg font-semibold text-gray-900 dark:text-white">Garage & Créneau</h2>
      </div>
      <div class="px-6 py-4">
        <div class="grid grid-cols-2 gap-6">
          <div>
            <label class="block text-xs font-semibold text-gray-600 dark:text-gray-400 uppercase tracking-wide mb-2">Garage</label>
            <div class="text-sm text-gray-900 dark:text-white">{{@model.garageName}}</div>
          </div>
          <div>
            <label class="block text-xs font-semibold text-gray-600 dark:text-gray-400 uppercase tracking-wide mb-2">Date prévue</label>
            <div class="text-sm text-gray-900 dark:text-white">{{format-date @model.scheduledDate "dd/MM/yyyy"}}</div>
          </div>
          <div>
            <label class="block text-xs font-semibold text-gray-600 dark:text-gray-400 uppercase tracking-wide mb-2">Heure</label>
            <div class="text-sm text-gray-900 dark:text-white">{{@model.scheduledTime}}</div>
          </div>
        </div>
      </div>
    </div>

    <!-- Section: Résumé des Coûts -->
    <div class="bg-white dark:bg-gray-800 rounded-lg shadow-sm border border-gray-200 dark:border-gray-700">
      <div class="px-6 py-4 border-b border-gray-200 dark:border-gray-700">
        <h2 class="text-lg font-semibold text-gray-900 dark:text-white">Résumé des coûts</h2>
      </div>
      <div class="px-6 py-4">
        <div class="space-y-3">
          <div class="flex justify-between text-sm">
            <span class="text-gray-700 dark:text-gray-300">Produits</span>
            <strong class="text-gray-900 dark:text-white">{{@model.totalProductsCostMad}} MAD</strong>
          </div>
          <div class="flex justify-between text-sm border-t border-gray-200 dark:border-gray-700 pt-3">
            <span class="text-gray-700 dark:text-gray-300">Service garage</span>
            <strong class="text-gray-900 dark:text-white">{{@model.garageServiceCostMad}} MAD</strong>
          </div>
          <div class="flex justify-between text-sm">
            <span class="text-gray-700 dark:text-gray-300">TVA</span>
            <strong class="text-gray-900 dark:text-white">{{@model.taxMad}} MAD</strong>
          </div>
          {{#if @model.discountMad}}
            <div class="flex justify-between text-sm text-green-600 dark:text-green-400">
              <span>Remise</span>
              <strong>-{{@model.discountMad}} MAD</strong>
            </div>
          {{/if}}
          <div class="flex justify-between text-base font-bold border-t-2 border-gray-900 dark:border-white pt-3 mt-3 text-gray-900 dark:text-white">
            <span>TOTAL</span>
            <span>{{@model.totalCostMad}} MAD</span>
          </div>
        </div>
      </div>
    </div>

    <!-- Section: Paiement -->
    <div class="bg-white dark:bg-gray-800 rounded-lg shadow-sm border border-gray-200 dark:border-gray-700">
      <div class="px-6 py-4 border-b border-gray-200 dark:border-gray-700">
        <h2 class="text-lg font-semibold text-gray-900 dark:text-white">Paiement</h2>
      </div>
      <div class="px-6 py-4">
        <div class="grid grid-cols-2 gap-6">
          <div>
            <label class="block text-xs font-semibold text-gray-600 dark:text-gray-400 uppercase tracking-wide mb-2">Statut paiement</label>
            <span class="inline-block px-3 py-1 bg-red-100 dark:bg-red-900 text-red-800 dark:text-red-200 rounded text-xs font-semibold">{{@model.paymentStatus}}</span>
          </div>
        </div>
      </div>
    </div>

    <!-- Section: Notes Client -->
    {{#if @model.customerMessage}}
      <div class="bg-white dark:bg-gray-800 rounded-lg shadow-sm border border-gray-200 dark:border-gray-700">
        <div class="px-6 py-4 border-b border-gray-200 dark:border-gray-700">
          <h2 class="text-lg font-semibold text-gray-900 dark:text-white">Notes client</h2>
        </div>
        <div class="px-6 py-4">
          <p class="text-sm text-gray-700 dark:text-gray-300 leading-relaxed">{{@model.customerMessage}}</p>
        </div>
      </div>
    {{/if}}

  {{else}}
    <div class="flex items-center justify-center py-16 bg-white dark:bg-gray-800 rounded-lg">
      <p class="text-gray-600 dark:text-gray-400">Chargement...</p>
    </div>
  {{/if}}
</div>