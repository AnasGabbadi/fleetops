<div class="form-wrapper" ...attributes>

    {{! ✅ CRÉATION SIMPLE: JUSTE 6 CHAMPS }}
    <ContentPanel @title="Créer une nouvelle flotte" @open={{true}} @wrapperClass="bordered-top">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-2 text-xs no-input-group-padding">

            {{! Nom de la flotte }}
            <InputGroup @name="Nom de la flotte" @wrapperClass="mb-0i">
                <Input @value={{@resource.name}} @type="text" class="w-full form-input"
                    placeholder="Ex: Fleet Casablanca" disabled={{cannot-write @resource}} />
            </InputGroup>

            {{! Statut }}
            <InputGroup @name="Statut" @wrapperClass="mb-0i">
                <div class="fleetbase-model-select fleetbase-power-select ember-model-select">
                    <PowerSelect @options={{get-fleet-ops-options "fleetStatuses" }} @selected={{find-by "value"
                        @resource.status (get-fleet-ops-options "fleetStatuses" )}} @onChange={{set-model-attr
                        @resource "status" }} @placeholder="Sélectionner un statut"
                        @triggerClass="form-select form-input" @disabled={{cannot-write @resource}} as |status|>
                        <div class="text-sm">
                            <div class="font-semibold normalize-in-trigger">{{status.label}}</div>
                            <div class="hide-from-trigger">{{status.description}}</div>
                        </div>
                    </PowerSelect>
                </div>
            </InputGroup>

            {{! Niveau de flotte }}
            <InputGroup @name="Niveau de flotte" @wrapperClass="mb-0i">
                <PowerSelect @options={{array "PAYS" "VILLE" }} @selected={{@resource.fleet_level}}
                    @onChange={{fn (mut @resource.fleet_level)}} @placeholder="Sélectionner le niveau"
                    @triggerClass="form-select form-input" @disabled={{cannot-write @resource}} as |option|>
                    {{option}}
                </PowerSelect>
            </InputGroup>

            {{! Flotte parente }}
            <InputGroup @name="Flotte parente" @wrapperClass="mb-0i">
                <ModelSelect @modelName="fleet" @selectedModel={{@resource.parent_fleet}}
                    @placeholder="Sélectionner flotte parente" @triggerClass="form-select form-input"
                    @infiniteScroll={{false}} @renderInPlace={{true}} @onChange={{fn (mut @resource.parent_fleet)}}
                    @onChangeId={{fn (mut @resource.parent_fleet_uuid)}} @disabled={{cannot-write @resource}} as
                    |model|>
                    {{model.name}}
                </ModelSelect>
            </InputGroup>

            {{! Pays - MODIFIÉ: Fixé sur Morocco (disabled) }}
            <InputGroup @name="Pays" @wrapperClass="mb-0i">
                <Input @value={{@resource.country}} @type="text" class="w-full form-input bg-gray-100 dark:bg-gray-700"
                    disabled={{true}} />
            </InputGroup>

            {{! Ville - MODIFIÉ: PowerSelect dynamique avec API Kounhany }}
            <InputGroup @name="Ville" @wrapperClass="mb-0i">
                <div class="fleetbase-model-select fleetbase-power-select ember-model-select">
                    <PowerSelect
                        @options={{this.cities}}
                        @selected={{this.selectedCity}}
                        @onChange={{this.onCityChange}}
                        @searchField="city"
                        @placeholder="Sélectionner une ville..."
                        @triggerClass="form-select form-input"
                        @disabled={{cannot-write @resource}}
                        @allowClear={{true}}
                        as |city|>
                        {{city.city}}
                    </PowerSelect>
                </div>
            </InputGroup>

        </div>
    </ContentPanel>

</div>