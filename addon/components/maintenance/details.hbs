<div class="details-wrapper" ...attributes>

    {{!-- SECTION 1 : Informations générales --}}
    <ContentPanel @title="Détails de la maintenance" @open={{true}} @wrapperClass="bordered-top">
        <div class="grid grid-cols-2 gap-2 text-xs dark:text-gray-100">

            <div class="field-info-container">
                <div class="field-name">Référence</div>
                <ClickToCopy @value={{@resource.publicId}} class="field-value">
                    {{n-a @resource.publicId}}
                </ClickToCopy>
            </div>

            <div class="field-info-container">
                <div class="field-name">Type de maintenance</div>
                <div class="field-value">{{n-a @resource.maintenanceType}}</div>
            </div>

            <div class="field-info-container">
                <div class="field-name">Statut</div>
                <div class="field-value">
                    <Badge @status={{@resource.status}}>
                        {{n-a @resource.statusLabel}}
                    </Badge>
                </div>
            </div>

            <div class="field-info-container">
                <div class="field-name">Priorité</div>
                <div class="field-value">
                    {{#if (eq @resource.priority "critical")}}
                        <Badge @status="danger">Critique</Badge>
                    {{else if (eq @resource.priority "high")}}
                        <Badge @status="warning">Haute</Badge>
                    {{else if (eq @resource.priority "medium")}}
                        <Badge @status="info">Moyenne</Badge>
                    {{else}}
                        <Badge @status="default">Basse</Badge>
                    {{/if}}
                </div>
            </div>

            <div class="field-info-container">
                <div class="field-name">Ville</div>
                <div class="field-value">{{n-a @resource.city}}</div>
            </div>

            <div class="field-info-container">
                <div class="field-name">Adresse</div>
                <div class="field-value">{{n-a @resource.address}}</div>
            </div>

            <div class="field-info-container">
                <div class="field-name">Date prévue</div>
                <div class="field-value">{{n-a @resource.scheduledDate}}</div>
            </div>

            <div class="field-info-container">
                <div class="field-name">Heure prévue</div>
                <div class="field-value">{{n-a @resource.scheduledTime}}</div>
            </div>

            <div class="field-info-container">
                <div class="field-name">Démarré le</div>
                <div class="field-value">{{format-date @resource.startedAt}}</div>
            </div>

            <div class="field-info-container">
                <div class="field-name">Terminé le</div>
                <div class="field-value">{{format-date @resource.completedAt}}</div>
            </div>

            <div class="field-info-container">
                <div class="field-name">Créé le</div>
                <div class="field-value">{{format-date @resource.createdAt}}</div>
            </div>

        </div>
    </ContentPanel>

    {{!-- SECTION 2 : Coûts --}}
    <ContentPanel @title="Détail des coûts" @open={{true}} @wrapperClass="bordered-top">
        <div class="grid grid-cols-2 gap-2 text-xs dark:text-gray-100">

            <div class="field-info-container">
                <div class="field-name">Coût produits</div>
                <div class="field-value">{{n-a @resource.formattedProductsCost}}</div>
            </div>

            <div class="field-info-container">
                <div class="field-name">Coût service garage</div>
                <div class="field-value">{{n-a @resource.formattedServiceCost}}</div>
            </div>

            <div class="field-info-container">
                <div class="field-name">Sous-total</div>
                <div class="field-value">{{n-a @resource.formattedSubtotal}}</div>
            </div>

            <div class="field-info-container">
                <div class="field-name">TVA</div>
                <div class="field-value">{{n-a @resource.formattedTax}}</div>
            </div>

            <div class="field-info-container">
                <div class="field-name">Remise</div>
                <div class="field-value">{{n-a @resource.formattedDiscount}}</div>
            </div>

            <div class="field-info-container">
                <div class="field-name">Total (MAD)</div>
                <div class="field-value font-bold text-sm">
                    {{n-a @resource.formattedTotal}}
                </div>
            </div>

        </div>
    </ContentPanel>

    {{!-- SECTION 3 : Paiement --}}
    <ContentPanel @title="Paiement" @open={{true}} @wrapperClass="bordered-top">
        <div class="grid grid-cols-2 gap-2 text-xs dark:text-gray-100">

            <div class="field-info-container">
                <div class="field-name">Statut paiement</div>
                <div class="field-value">
                    <Badge @status={{@resource.paymentStatus}}>
                        {{n-a @resource.paymentStatusLabel}}
                    </Badge>
                </div>
            </div>

            <div class="field-info-container">
                <div class="field-name">Méthode de paiement</div>
                <div class="field-value">{{n-a @resource.paymentMethod}}</div>
            </div>

            <div class="field-info-container">
                <div class="field-name">Référence paiement</div>
                <div class="field-value">{{n-a @resource.paymentReference}}</div>
            </div>

            <div class="field-info-container">
                <div class="field-name">Payé le</div>
                <div class="field-value">{{format-date @resource.paidAt}}</div>
            </div>

        </div>
    </ContentPanel>

    {{!-- SECTION 4 : Notes --}}
    {{#if (or @resource.customerMessage @resource.notes)}}
    <ContentPanel @title="Notes & Messages" @open={{true}} @wrapperClass="bordered-top">
        <div class="grid grid-cols-1 gap-2 text-xs dark:text-gray-100">

            {{#if @resource.customerMessage}}
            <div class="field-info-container">
                <div class="field-name">Message client</div>
                <div class="field-value">{{@resource.customerMessage}}</div>
            </div>
            {{/if}}

            {{#if @resource.notes}}
            <div class="field-info-container">
                <div class="field-name">Notes internes</div>
                <div class="field-value">{{@resource.notes}}</div>
            </div>
            {{/if}}

        </div>
    </ContentPanel>
    {{/if}}

    <CustomField::Yield @subject={{@resource}} @viewMode={{true}} @wrapperClass="bordered-top" />

</div>
