<div class="flex flex-col h-full w-full">

  {{!-- Header --}}
  <div class="flex-shrink-0 px-6 py-4 border-b
              border-gray-200 dark:border-gray-700">
    <h3 class="text-xl font-bold tracking-tight
               text-gray-900 dark:text-gray-100">
      ✅ Récapitulatif & Confirmation
    </h3>
    <p class="text-sm mt-0.5 text-gray-500 dark:text-gray-400">
      Vérifiez les informations avant de confirmer votre demande
    </p>
  </div>

  {{!-- Contenu scrollable --}}
  <div class="flex-1 overflow-y-auto p-6 space-y-5 min-h-0">

    {{!-- 1. Véhicule --}}
    <div class="rounded-xl border overflow-hidden
                bg-white dark:bg-gray-900
                border-gray-200 dark:border-gray-700">
      <div class="flex items-center gap-2 px-4 py-3 border-b
                  bg-gray-50 dark:bg-gray-800
                  border-gray-200 dark:border-gray-700">
        <span class="text-base">🚗</span>
        <h4 class="font-semibold text-sm text-gray-700 dark:text-gray-300">
          Véhicule
        </h4>
      </div>
      <div class="px-4 py-3 grid grid-cols-2 sm:grid-cols-3 gap-3">
        <div>
          <p class="text-xs text-gray-400 dark:text-gray-500 uppercase tracking-wide font-semibold">
            Véhicule
          </p>
          <p class="text-sm font-semibold mt-0.5 text-gray-900 dark:text-gray-100">
            {{@wizardData.vehicle.year}}
            {{@wizardData.vehicle.make}}
            {{@wizardData.vehicle.model}}
          </p>
        </div>
        <div>
          <p class="text-xs text-gray-400 dark:text-gray-500 uppercase tracking-wide font-semibold">
            Immatriculation
          </p>
          <p class="text-sm font-semibold mt-0.5 font-mono
                    text-gray-900 dark:text-gray-100">
            {{@wizardData.vehicle.plate_number}}
          </p>
        </div>
        <div>
          <p class="text-xs text-gray-400 dark:text-gray-500 uppercase tracking-wide font-semibold">
            VIN
          </p>
          <p class="text-sm font-mono mt-0.5 truncate
                    text-gray-500 dark:text-gray-400">
            {{@wizardData.vehicle.vin}}
          </p>
        </div>
        <div>
          <p class="text-xs text-gray-400 dark:text-gray-500 uppercase tracking-wide font-semibold">
            Type de prestation
          </p>
          <span class="inline-block mt-1 px-2 py-0.5 rounded-full text-xs font-semibold
                       bg-purple-100 dark:bg-purple-500/20
                       text-purple-700 dark:text-purple-400">
            🔧 {{@wizardData.maintenanceType}}
          </span>
        </div>
        <div>
          <p class="text-xs text-gray-400 dark:text-gray-500 uppercase tracking-wide font-semibold">
            Ville
          </p>
          <span class="inline-block mt-1 px-2 py-0.5 rounded-full text-xs font-semibold
                       bg-green-100 dark:bg-green-500/20
                       text-green-700 dark:text-green-400">
            📍 {{@wizardData.city}}
          </span>
        </div>
      </div>
    </div>

    {{!-- 2. Produits --}}
    {{#if @wizardData.cartItems.length}}
      <div class="rounded-xl border overflow-hidden
                  bg-white dark:bg-gray-900
                  border-gray-200 dark:border-gray-700">
        <div class="flex items-center justify-between px-4 py-3 border-b
                    bg-gray-50 dark:bg-gray-800
                    border-gray-200 dark:border-gray-700">
          <div class="flex items-center gap-2">
            <span class="text-base">📦</span>
            <h4 class="font-semibold text-sm text-gray-700 dark:text-gray-300">
              Produits sélectionnés
            </h4>
          </div>
          <span class="text-xs font-bold px-2 py-0.5 rounded-full
                       bg-sky-100 dark:bg-sky-500/20
                       text-sky-600 dark:text-sky-400">
            {{@wizardData.cartItems.length}} article(s)
          </span>
        </div>

        <div class="divide-y divide-gray-100 dark:divide-gray-800">
          {{#each this.cartItemsWithTotal as |item|}}
            <div class="flex items-center justify-between px-4 py-3 gap-3">
              <div class="flex-1 min-w-0">
                <p class="text-sm font-semibold truncate
                          text-gray-900 dark:text-gray-100">
                  {{item.name}}
                </p>
                <p class="text-xs font-mono text-gray-400 dark:text-gray-500">
                  {{item.sku}}
                </p>
              </div>
              <div class="flex items-center gap-3 flex-shrink-0 text-sm">
                <span class="text-gray-400 dark:text-gray-500">
                  {{item.quantity}} × {{item.unitPrice}} MAD
                </span>
                <span class="font-bold text-blue-600 dark:text-sky-400">
                  {{item.totalPrice}} MAD
                </span>
              </div>
            </div>
          {{/each}}
        </div>

        {{!-- Total produits --}}
        <div class="flex justify-between items-center px-4 py-3 border-t
                    bg-gray-50 dark:bg-gray-800
                    border-gray-200 dark:border-gray-700">
          <span class="text-sm font-semibold text-gray-600 dark:text-gray-300">
            Total produits
          </span>
          <strong class="text-base font-bold text-blue-600 dark:text-sky-400">
            {{this.cartTotal}} MAD
          </strong>
        </div>
      </div>
    {{/if}}

    {{!-- 3. Garage & Rendez-vous --}}
    {{#if @wizardData.garage}}
      <div class="rounded-xl border overflow-hidden
                  bg-white dark:bg-gray-900
                  border-gray-200 dark:border-gray-700">
        <div class="flex items-center gap-2 px-4 py-3 border-b
                    bg-gray-50 dark:bg-gray-800
                    border-gray-200 dark:border-gray-700">
          <span class="text-base">🏪</span>
          <h4 class="font-semibold text-sm text-gray-700 dark:text-gray-300">
            Garage & Rendez-vous
          </h4>
        </div>
        <div class="px-4 py-3 grid grid-cols-1 sm:grid-cols-2 gap-3">
          <div>
            <p class="text-xs text-gray-400 dark:text-gray-500 uppercase tracking-wide font-semibold">
              Garage
            </p>
            <p class="text-sm font-semibold mt-0.5 text-gray-900 dark:text-gray-100">
              {{@wizardData.garage.name}}
            </p>
            <p class="text-xs mt-0.5 text-gray-400 dark:text-gray-500">
              📍 {{@wizardData.garage.address}}
            </p>
          </div>
          <div>
            <p class="text-xs text-gray-400 dark:text-gray-500 uppercase tracking-wide font-semibold">
              Horaires
            </p>
            <p class="text-sm mt-0.5 text-gray-700 dark:text-gray-300">
              🕐 {{@wizardData.garage.workingHoursStart}}
              – {{@wizardData.garage.workingHoursEnd}}
            </p>
            {{#if @wizardData.garage.phone}}
              <p class="text-xs mt-0.5 text-gray-400 dark:text-gray-500">
                📞 {{@wizardData.garage.phone}}
              </p>
            {{/if}}
          </div>
          {{#if @wizardData.appointmentSlot}}
            <div class="sm:col-span-2">
              <p class="text-xs text-gray-400 dark:text-gray-500 uppercase tracking-wide font-semibold">
                Créneau confirmé
              </p>
              <div class="inline-flex items-center gap-2 mt-1.5 px-3 py-2 rounded-lg
                          bg-green-50 dark:bg-green-500/10
                          border border-green-200 dark:border-green-500/30">
                <div class="w-2 h-2 rounded-full bg-green-500"></div>
                <p class="text-sm font-semibold text-green-700 dark:text-green-400">
                  📅 {{@wizardData.appointmentSlot.date}}
                  à {{@wizardData.appointmentSlot.time}}
                </p>
              </div>
            </div>
          {{/if}}
        </div>
      </div>
    {{/if}}

    {{!-- 4. Notes optionnelles --}}
    <div class="rounded-xl border overflow-hidden
                bg-white dark:bg-gray-900
                border-gray-200 dark:border-gray-700">
      <div class="flex items-center gap-2 px-4 py-3 border-b
                  bg-gray-50 dark:bg-gray-800
                  border-gray-200 dark:border-gray-700">
        <span class="text-base">📝</span>
        <h4 class="font-semibold text-sm text-gray-700 dark:text-gray-300">
          Notes additionnelles
          <span class="ml-1 text-xs font-normal text-gray-400">(optionnel)</span>
        </h4>
      </div>
      <div class="px-4 py-3">
        <textarea
          rows="3"
          placeholder="Décrivez le problème ou ajoutez des informations utiles pour le garage..."
          value={{this.notes}}
          {{on "input" this.updateNotes}}
          class="w-full form-input rounded-lg resize-none transition
                 bg-white dark:bg-gray-800
                 border-gray-300 dark:border-gray-600
                 text-gray-800 dark:text-gray-100
                 placeholder-gray-400 dark:placeholder-gray-500
                 hover:border-sky-400 dark:hover:border-sky-500
                 text-sm"
        ></textarea>
      </div>
    </div>

    {{!-- 5. Résumé total --}}
    <div class="rounded-xl border overflow-hidden
                bg-gradient-to-r from-sky-50 to-blue-50
                dark:from-sky-500/10 dark:to-blue-500/10
                border-sky-200 dark:border-sky-500/30">
      <div class="px-5 py-4 flex flex-col sm:flex-row items-start sm:items-center
                  justify-between gap-3">
        <div>
          <p class="text-sm font-semibold text-gray-700 dark:text-gray-300">
            💰 Estimation totale
          </p>
          <p class="text-xs text-gray-400 dark:text-gray-500 mt-0.5">
            Produits + frais garage
          </p>
        </div>
        <div class="text-right">
          <p class="text-2xl font-bold text-blue-600 dark:text-sky-400">
            {{this.grandTotal}} MAD
          </p>
          <p class="text-xs text-gray-400 dark:text-gray-500">
            TTC estimé
          </p>
        </div>
      </div>
    </div>

    {{!-- Erreur --}}
    {{#if this.errorMessage}}
      <div class="rounded-xl px-4 py-3 border
                  bg-red-50 dark:bg-red-500/10
                  border-red-200 dark:border-red-500/30">
        <p class="text-sm font-semibold text-red-600 dark:text-red-400">
          ❌ {{this.errorMessage}}
        </p>
      </div>
    {{/if}}

  </div>

  {{!-- Actions Footer --}}
  <div class="flex-shrink-0 flex flex-col sm:flex-row justify-between items-center
              gap-3 px-6 py-4 border-t
              bg-white dark:bg-gray-900
              border-gray-200 dark:border-gray-700">
    <div class="flex gap-2 w-full sm:w-auto">
      <button
        class="btn btn-secondary font-medium"
        disabled={{this.isSubmitting}}
        {{on "click" @onPrevious}}
      >
        ← Retour
      </button>
      <button
        class="btn btn-secondary font-medium"
        disabled={{this.isSubmitting}}
        {{on "click" @onCancel}}
      >
        ✕ Annuler
      </button>
    </div>

    <button
      class="btn btn-primary w-full sm:w-auto font-semibold px-8
             disabled:opacity-40 disabled:cursor-not-allowed
             bg-gradient-to-r from-sky-500 to-blue-600
             hover:from-sky-600 hover:to-blue-700
             shadow-md shadow-sky-500/20"
      disabled={{this.isSubmitting}}
      {{on "click" this.confirmRequest}}
    >
      {{#if this.isSubmitting}}
        <span class="animate-spin mr-2">⚙️</span> Création en cours...
      {{else}}
        🚀 Confirmer la demande
      {{/if}}
    </button>
  </div>

</div>