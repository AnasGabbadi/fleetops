<div class="flex flex-col h-full w-full">

  {{!-- Header avec infos sélectionnées du Step 1 --}}
  <div class="flex-shrink-0 px-6 py-4 border-b
              border-gray-200 dark:border-gray-700">
    {{!-- Infos Step 1 --}}
    <div class="flex flex-wrap gap-2 mt-2">
      {{#if this.vehicle}}
      <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-xs font-semibold
               bg-sky-100 dark:bg-sky-500/20
               text-sky-700 dark:text-sky-400
               border border-sky-200 dark:border-sky-500/30">
        🚗 {{this.vehicle.year}} {{this.vehicle.make}} {{this.vehicle.model}}
      </span>
      {{/if}}

      {{#if this.maintenanceType}}
      <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-xs font-semibold
               bg-purple-100 dark:bg-purple-500/20
               text-purple-700 dark:text-purple-400
               border border-purple-200 dark:border-purple-500/30">
        🔧 {{this.maintenanceType}}
      </span>
      {{/if}}

      {{#if this.city}}
      <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-xs font-semibold
               bg-green-100 dark:bg-green-500/20
               text-green-700 dark:text-green-400
               border border-green-200 dark:border-green-500/30">
        📍 {{this.city}}
      </span>
      {{/if}}
    </div>
  </div>

  {{#if this.isLoading}}
  <div class="flex items-center justify-center flex-1
                text-gray-500 dark:text-gray-400">
    <div class="text-center space-y-2">
      <div class="animate-spin text-2xl">⚙️</div>
      <span class="text-sm">Chargement des produits...</span>
    </div>
  </div>

  {{else if this.products.length}}

  {{!-- Search & Filter --}}
  <div class="flex-shrink-0 px-6 py-3 border-b space-y-3
                bg-gray-50 dark:bg-gray-800
                border-gray-200 dark:border-gray-700">

    {{!-- Ligne 2 : Boutons filtre rapide --}}
    <div class="flex flex-wrap gap-2">
      <span class="text-xs font-semibold self-center
                     text-gray-400 dark:text-gray-500">
        Filtre rapide :
      </span>

      <button type="button" class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg text-xs font-semibold
                 border transition-all duration-150
                 {{if (eq this.quickFilter 'origine')
                   'bg-blue-600 dark:bg-blue-500 border-blue-600 dark:border-blue-500 text-white shadow-sm'
                   'bg-white dark:bg-gray-700
                    border-gray-300 dark:border-gray-600
                    text-gray-600 dark:text-gray-300
                    hover:border-blue-400 dark:hover:border-blue-500
                    hover:text-blue-600 dark:hover:text-blue-400'}}" {{on "click" (fn this.setQuickFilter 'origine'
        )}}>
        ⭐ Pièce d'origine
      </button>

      <button type="button" class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg text-xs font-semibold
                 border transition-all duration-150
                 {{if (eq this.quickFilter 'premium')
                   'bg-purple-600 dark:bg-purple-500 border-purple-600 dark:border-purple-500 text-white shadow-sm'
                   'bg-white dark:bg-gray-700
                    border-gray-300 dark:border-gray-600
                    text-gray-600 dark:text-gray-300
                    hover:border-purple-400 dark:hover:border-purple-500
                    hover:text-purple-600 dark:hover:text-purple-400'}}" {{on "click" (fn this.setQuickFilter 'premium'
        )}}>
        💎 Pièce Premium
      </button>

      <button type="button" class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg text-xs font-semibold
                 border transition-all duration-150
                 {{if (eq this.quickFilter 'economique')
                   'bg-green-600 dark:bg-green-500 border-green-600 dark:border-green-500 text-white shadow-sm'
                   'bg-white dark:bg-gray-700
                    border-gray-300 dark:border-gray-600
                    text-gray-600 dark:text-gray-300
                    hover:border-green-400 dark:hover:border-green-500
                    hover:text-green-600 dark:hover:text-green-400'}}" {{on "click" (fn
        this.setQuickFilter 'economique' )}}>
        💰 Pièce Moins Chère
      </button>

      {{#if this.quickFilter}}
      <button type="button" class="inline-flex items-center gap-1 px-2.5 py-1.5 rounded-lg text-xs font-medium
                   border transition-all
                   bg-white dark:bg-gray-700
                   border-gray-300 dark:border-gray-600
                   text-gray-400 dark:text-gray-500
                   hover:text-red-500 dark:hover:text-red-400
                   hover:border-red-300 dark:hover:border-red-500" {{on "click" (fn this.setQuickFilter null)}}>
        ✕ Réinitialiser
      </button>
      {{/if}}
    </div>
  </div>

  {{!-- Products & Cart --}}
  <div class="flex-1 flex gap-5 p-5 overflow-hidden w-full min-h-0">

    {{!-- Products Grid --}}
    <div class="flex-1 overflow-y-auto pr-1">
      {{#if this.filteredProducts.length}}
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {{#each this.filteredProducts as |product|}}
        <div class="flex flex-col rounded-xl border overflow-hidden
                          transition-all duration-150
                          bg-white dark:bg-gray-900
                          border-gray-200 dark:border-gray-700
                          hover:shadow-md hover:border-sky-300 dark:hover:border-sky-600">

          {{!-- Category Banner --}}
          <div class="h-24 flex items-center justify-center border-b px-3
                            bg-gray-50 dark:bg-gray-800
                            border-gray-200 dark:border-gray-700">
            <span class="text-xs font-semibold text-center uppercase tracking-wide
                               text-gray-400 dark:text-gray-500">
              {{product.category}}
            </span>
          </div>

          {{!-- Product Info --}}
          <div class="p-4 space-y-3 flex flex-col flex-1">
            <div>
              <h4 class="font-semibold text-sm leading-snug line-clamp-2
                               text-gray-900 dark:text-gray-100">
                {{product.name}}
              </h4>
              <p class="text-xs mt-1 font-mono
                               text-gray-400 dark:text-gray-500">
                {{product.sku}}
              </p>
            </div>

            <div class="text-lg font-bold
                              text-blue-600 dark:text-sky-400">
              {{product.priceMad}}
              <span class="text-xs font-normal
                                 text-gray-400 dark:text-gray-500">
                {{product.currency}}
              </span>
            </div>

            <div>
              {{#if product.isInStock}}
              <span class="inline-block px-2 py-1 text-xs rounded-full font-semibold
                                   bg-green-100 dark:bg-green-900/30
                                   text-green-700 dark:text-green-400">
                ✓ En stock ({{product.stockQuantity}})
              </span>
              {{else}}
              <span class="inline-block px-2 py-1 text-xs rounded-full font-semibold
                                   bg-red-100 dark:bg-red-900/30
                                   text-red-600 dark:text-red-400">
                ✕ Rupture
              </span>
              {{/if}}
            </div>

            <div class="flex gap-2 pt-2 mt-auto border-t
            border-gray-100 dark:border-gray-700">
              <input type="number" min="1" max={{product.stockQuantity}} value={{(get this.quantities product.id)}}
                {{on "change" (fn this.updateProductQuantity product.id)}} class="form-input form-input-sm w-16 rounded-lg text-center
           bg-white dark:bg-gray-700
           border-gray-300 dark:border-gray-600
           text-gray-800 dark:text-gray-100
           disabled:opacity-40" disabled={{not product.isInStock}}>
              <button class="flex-1 btn btn-primary btn-sm rounded-lg
           disabled:opacity-40 disabled:cursor-not-allowed" disabled={{not product.isInStock}} {{on "click" (fn
                this.addToCart product)}}>
                + Ajouter
              </button>
            </div>
          </div>
        </div>
        {{/each}}
      </div>
      {{else}}
      <div class="flex items-center justify-center h-full">
        <div class="text-center space-y-2">
          <p class="text-2xl">🔍</p>
          <p class="text-sm font-medium
                        text-gray-500 dark:text-gray-400">
            Aucun produit ne correspond
          </p>
        </div>
      </div>
      {{/if}}
    </div>

    {{!-- Cart Sidebar --}}
    <div class="w-72 flex-shrink-0 flex flex-col min-h-0">
      <div class="flex flex-col h-full rounded-xl border shadow-sm
                    bg-white dark:bg-gray-900
                    border-gray-200 dark:border-gray-700">

        {{!-- Cart Header --}}
        <div class="flex-shrink-0 px-4 py-3 border-b
                      border-gray-100 dark:border-gray-700">
          <h4 class="font-semibold text-sm
                       text-gray-900 dark:text-gray-100">
            📦 Panier
            <span class="ml-1.5 px-2 py-0.5 rounded-full text-xs font-bold
                           bg-sky-100 dark:bg-sky-500/20
                           text-sky-600 dark:text-sky-400">
              {{this.cartItems.length}}
            </span>
          </h4>
        </div>

        {{#if this.cartItems.length}}

        {{!-- Cart Items --}}
        <div class="flex-1 overflow-y-auto p-3 space-y-2 min-h-0">
          {{#each this.cartItems as |item|}}
          <div class="rounded-lg p-3 text-xs border
                            bg-gray-50 dark:bg-gray-800
                            border-gray-200 dark:border-gray-700">
            <div class="flex justify-between items-start gap-2 mb-2">
              <div class="flex-1 min-w-0">
                <p class="font-semibold line-clamp-1
                                text-gray-900 dark:text-gray-100">
                  {{item.name}}
                </p>
                <p class="font-mono mt-0.5
                                text-gray-400 dark:text-gray-500">
                  {{item.sku}}
                </p>
              </div>
              <button class="flex-shrink-0 w-5 h-5 rounded-full flex items-center justify-center
                             transition text-xs font-bold
                             text-red-400 dark:text-red-400
                             hover:bg-red-100 dark:hover:bg-red-500/20" {{on "click" (fn this.removeFromCart
                item.productId)}}>
                ✕
              </button>
            </div>

            <div class="flex gap-1.5 items-center mb-2">
              <input type="number" min="1" value={{item.quantity}} {{on "change" (fn this.updateQuantity item)}} class="form-input form-input-sm w-12 rounded text-center
                             bg-white dark:bg-gray-700
                             border-gray-300 dark:border-gray-600
                             text-gray-800 dark:text-gray-100">
              <span class="text-gray-400 dark:text-gray-500">×</span>
              <span class="text-gray-600 dark:text-gray-300 font-medium">
                {{item.unitPrice}}
              </span>
            </div>

            <div class="text-right font-bold
                              text-blue-600 dark:text-sky-400">
              {{this.getItemTotal item}} {{item.currency}}
            </div>
          </div>
          {{/each}}
        </div>

        {{!-- Cart Footer --}}
        <div class="flex-shrink-0 px-4 py-3 space-y-3 border-t
                        border-gray-100 dark:border-gray-700">
          <div class="flex justify-between items-center">
            <span class="text-sm font-semibold
                             text-gray-600 dark:text-gray-300">
              Total
            </span>
            <strong class="text-base font-bold
                               text-blue-600 dark:text-sky-400">
              {{this.cartTotal}} MAD
            </strong>
          </div>
          <button class="w-full btn btn-secondary btn-sm rounded-lg" {{on "click" this.clearCart}}>
            🗑 Vider le panier
          </button>
        </div>

        {{else}}
        <div class="flex items-center justify-center flex-1 p-6 text-center">
          <div class="space-y-2">
            <p class="text-2xl">🛒</p>
            <p class="text-sm font-medium
                          text-gray-400 dark:text-gray-500">
              Panier vide
            </p>
            <p class="text-xs
                          text-gray-400 dark:text-gray-600">
              Ajoutez des produits depuis la liste
            </p>
          </div>
        </div>
        {{/if}}

      </div>
    </div>
  </div>

  {{else}}
  <div class="flex-1 flex items-center justify-center">
    <div class="text-center space-y-2">
      <p class="text-2xl">📦</p>
      <p class="text-sm font-medium
                  text-gray-500 dark:text-gray-400">
        Aucun produit disponible
      </p>
    </div>
  </div>
  {{/if}}

  {{!-- Actions Footer --}}
  <div
    class="border-t border-gray-200 dark:border-gray-700 px-6 py-4 flex flex-col sm:flex-row justify-between gap-3 flex-shrink-0 bg-white dark:bg-gray-800 w-full">
    <div class="flex gap-2">
      <button class="btn btn-secondary" {{on "click" @onPrevious}}>← Retour</button>
      <button class="btn btn-secondary" {{on "click" @onCancel}}>Annuler</button>
    </div>
    <button class="btn btn-primary" disabled={{not this.isStep2Valid}} {{on "click" @onNext}}>Suivant →</button>
  </div>

</div>