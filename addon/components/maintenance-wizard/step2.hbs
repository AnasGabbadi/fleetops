<div class="flex flex-col h-full w-full">

  {{!-- Header badges --}}
  <div class="flex-shrink-0 px-6 py-4 border-b
              border-gray-200 dark:border-gray-700">
    <div class="flex flex-wrap gap-2 mt-2">
      {{#if @vehicle}}
        <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-xs font-semibold
                     bg-sky-100 dark:bg-sky-500/20 text-sky-700 dark:text-sky-400
                     border border-sky-200 dark:border-sky-500/30">
          🚗 {{@vehicle.year}} {{@vehicle.make}} {{@vehicle.model}}
        </span>
      {{/if}}
      {{#if @maintenanceType}}
        <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-xs font-semibold
                     bg-purple-100 dark:bg-purple-500/20 text-purple-700 dark:text-purple-400
                     border border-purple-200 dark:border-purple-500/30">
          🔧 {{@maintenanceType}}
        </span>
      {{/if}}
      {{#if @city}}
        <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-xs font-semibold
                     bg-green-100 dark:bg-green-500/20 text-green-700 dark:text-green-400
                     border border-green-200 dark:border-green-500/30">
          📍 {{@city}}
        </span>
      {{/if}}
      {{#if @cartItems.length}}
        <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-xs font-semibold
                     bg-orange-100 dark:bg-orange-500/20 text-orange-700 dark:text-orange-400
                     border border-orange-200 dark:border-orange-500/30">
          📦 {{@cartItems.length}} produit(s) — {{this.cartTotal}} MAD
        </span>
      {{/if}}
    </div>
  </div>

  {{!-- Search & Filter --}}
  <div class="flex-shrink-0 px-6 py-3 border-b space-y-3
              bg-gray-50 dark:bg-gray-800
              border-gray-200 dark:border-gray-700">

    <div class="flex flex-wrap gap-2">
      <span class="text-xs font-semibold self-center
                   text-gray-400 dark:text-gray-500">Trier :</span>

      <button type="button"
        class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg text-xs font-semibold
               border transition-all duration-150
               {{if (eq this.sortBy 'rating')
                 'bg-yellow-500 border-yellow-500 text-white shadow-sm'
                 'bg-white dark:bg-gray-700 border-gray-300 dark:border-gray-600
                  text-gray-600 dark:text-gray-300
                  hover:border-yellow-400 hover:text-yellow-600'}}"
        {{on "click" (fn this.setSortBy 'rating')}}
      >⭐ Meilleure note</button>

      <button type="button"
        class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg text-xs font-semibold
               border transition-all duration-150
               {{if (eq this.sortBy 'price')
                 'bg-green-600 border-green-600 text-white shadow-sm'
                 'bg-white dark:bg-gray-700 border-gray-300 dark:border-gray-600
                  text-gray-600 dark:text-gray-300
                  hover:border-green-400 hover:text-green-600'}}"
        {{on "click" (fn this.setSortBy 'price')}}
      >💰 Prix croissant</button>

      <button type="button"
        class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg text-xs font-semibold
               border transition-all duration-150
               {{if (eq this.sortBy 'name')
                 'bg-sky-500 border-sky-500 text-white shadow-sm'
                 'bg-white dark:bg-gray-700 border-gray-300 dark:border-gray-600
                  text-gray-600 dark:text-gray-300
                  hover:border-sky-400 hover:text-sky-600'}}"
        {{on "click" (fn this.setSortBy 'name')}}
      >🔤 Nom A-Z</button>
    </div>

  </div>

  {{!-- Contenu principal --}}
  {{#if this.isLoading}}
    <div class="flex items-center justify-center flex-1
                text-gray-500 dark:text-gray-400">
      <div class="text-center space-y-2">
        <div class="animate-spin text-2xl">⚙️</div>
        <span class="text-sm">Chargement des garages...</span>
      </div>
    </div>

  {{else}}
    <div class="flex-1 flex gap-5 p-5 overflow-hidden min-h-0">

      {{!-- Grille Garages --}}
      <div class="flex-1 overflow-y-auto pr-1">
        {{#if this.filteredGarages.length}}
          <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
            {{#each this.filteredGarages as |garage|}}
              <div class="flex flex-col rounded-xl border overflow-hidden
                          transition-all duration-150
                          {{if (eq garage.uuid this.selectedGarageUuid)
                            'border-sky-500 shadow-md shadow-sky-500/10'
                            'bg-white dark:bg-gray-900
                             border-gray-200 dark:border-gray-700
                             hover:shadow-md hover:border-sky-300 dark:hover:border-sky-600'}}">

                {{!-- Banner --}}
                <div class="h-24 flex flex-col items-center justify-center px-3 border-b relative
                            bg-gray-50 dark:bg-gray-800
                            border-gray-200 dark:border-gray-700">
                  <span class="text-2xl">🏪</span>
                  <span class="text-xs font-semibold text-center uppercase tracking-wide mt-1
                               text-gray-400 dark:text-gray-500">
                    {{garage.city}}
                  </span>
                  {{#if garage.rating}}
                    <span class="absolute top-2 right-2 inline-flex items-center gap-1
                                 px-2 py-0.5 rounded-full text-xs font-bold
                                 bg-yellow-100 dark:bg-yellow-500/20
                                 text-yellow-700 dark:text-yellow-400">
                      ⭐ {{garage.formattedRating}}
                    </span>
                  {{/if}}
                </div>

                {{!-- Infos --}}
                <div class="p-4 space-y-3 flex flex-col flex-1">
                  <div>
                    <h4 class="font-semibold text-sm leading-snug
                               text-gray-900 dark:text-gray-100">
                      {{garage.name}}
                    </h4>
                    <p class="text-xs mt-1 line-clamp-2
                               text-gray-400 dark:text-gray-500">
                      {{garage.description}}
                    </p>
                  </div>

                  <div class="text-lg font-bold text-blue-600 dark:text-sky-400">
                    {{garage.formattedPrice}}
                  </div>

                  <div class="space-y-1 text-xs text-gray-500 dark:text-gray-400">
                    <div class="flex items-center gap-1.5">
                      <span>🕐</span>
                      <span>{{garage.workingHoursStart}} – {{garage.workingHoursEnd}}</span>
                    </div>
                    <div class="flex items-center gap-1.5">
                      <span>📍</span>
                      <span class="truncate">{{garage.address}}</span>
                    </div>
                    {{#if garage.phone}}
                      <div class="flex items-center gap-1.5">
                        <span>📞</span>
                        <span>{{garage.phone}}</span>
                      </div>
                    {{/if}}
                  </div>

                  {{#if garage.servicesOffered.length}}
                    <div class="flex flex-wrap gap-1">
                      {{#each garage.servicesOffered as |service|}}
                        <span class="px-1.5 py-0.5 rounded text-xs
                                     bg-gray-100 dark:bg-gray-700
                                     text-gray-500 dark:text-gray-400">
                          {{service}}
                        </span>
                      {{/each}}
                    </div>
                  {{/if}}

                  <div class="pt-2 mt-auto border-t border-gray-100 dark:border-gray-700">
                    <button
                      type="button"
                      class="w-full btn btn-primary btn-sm rounded-lg font-semibold
                             {{if (eq garage.uuid this.selectedGarageUuid)
                               'bg-sky-600 hover:bg-sky-700' ''}}"
                      {{on "click" (fn this.selectGarage garage)}}
                    >
                      {{#if (eq garage.uuid this.selectedGarageUuid)}}
                        ✓ Garage sélectionné
                      {{else}}
                        📅 Prendre rendez-vous
                      {{/if}}
                    </button>
                  </div>
                </div>
              </div>
            {{/each}}
          </div>

        {{else}}
          <div class="flex items-center justify-center h-full">
            <div class="text-center space-y-2">
              <p class="text-2xl">🏪</p>
              <p class="text-sm font-medium text-gray-500 dark:text-gray-400">
                Aucun garage disponible
              </p>
            </div>
          </div>
        {{/if}}
      </div>

      {{!-- Panel Rendez-vous --}}
      {{#if this.selectedGarageUuid}}
        <div class="w-72 flex-shrink-0 flex flex-col min-h-0">
          <div class="flex flex-col h-full rounded-xl border shadow-sm
                      bg-white dark:bg-gray-900
                      border-gray-200 dark:border-gray-700">

            <div class="flex-shrink-0 px-4 py-3 border-b border-gray-100 dark:border-gray-700">
              <h4 class="font-semibold text-sm text-gray-900 dark:text-gray-100">
                📅 Rendez-vous
                <span class="ml-1.5 px-2 py-0.5 rounded-full text-xs font-bold
                             bg-sky-100 dark:bg-sky-500/20 text-sky-600 dark:text-sky-400">
                  {{this.selectedGarageName}}
                </span>
              </h4>
            </div>

            <div class="flex-shrink-0 px-4 py-3 border-b border-gray-100 dark:border-gray-700">
              <label class="text-xs font-semibold uppercase tracking-wide
                            text-gray-400 dark:text-gray-500">
                Choisir une date
              </label>
              <input
                type="date"
                value={{this.selectedDate}}
                {{on "change" this.updateDate}}
                class="mt-1.5 w-full form-input form-input-sm rounded-lg
                       bg-white dark:bg-gray-700
                       border-gray-300 dark:border-gray-600
                       text-gray-800 dark:text-gray-100"
              >
            </div>

            <div class="flex-1 overflow-y-auto p-3 min-h-0">
              {{#if this.isLoadingSlots}}
                <div class="flex items-center justify-center h-full gap-2
                            text-gray-400 dark:text-gray-500 text-sm">
                  <span class="animate-spin">⚙️</span>
                  <span>Chargement...</span>
                </div>

              {{else if this.availableSlots.length}}
                <div class="grid grid-cols-3 gap-2">
                  {{#each this.availableSlots as |slot|}}
                    <button
                      type="button"
                      class="px-2 py-2 rounded-lg text-xs font-semibold
                             border transition-all duration-150
                             {{if (eq slot.uuid this.selectedSlotUuid)
                               'bg-sky-500 dark:bg-sky-400 border-sky-500 text-white shadow-sm'
                               'bg-white dark:bg-gray-800
                                border-gray-200 dark:border-gray-700
                                text-gray-600 dark:text-gray-300
                                hover:border-sky-400 hover:text-sky-600
                                dark:hover:border-sky-500 dark:hover:text-sky-400'}}"
                      {{on "click" (fn this.selectSlot slot)}}
                    >
                      {{slot.time}}
                    </button>
                  {{/each}}
                </div>

              {{else if this.selectedDate}}
                <div class="flex items-center justify-center h-full">
                  <div class="text-center">
                    <p class="text-xl">😕</p>
                    <p class="text-xs font-medium text-gray-500 dark:text-gray-400 mt-1">
                      Aucun créneau disponible
                    </p>
                  </div>
                </div>

              {{else}}
                <div class="flex items-center justify-center h-full">
                  <p class="text-xs text-center text-gray-400 dark:text-gray-500">
                    Sélectionnez une date pour voir les créneaux
                  </p>
                </div>
              {{/if}}
            </div>

            {{#if this.selectedSlotUuid}}
              <div class="flex-shrink-0 px-4 py-3 border-t space-y-2
                          border-gray-100 dark:border-gray-700">
                <div class="flex items-center gap-2 p-2 rounded-lg
                            bg-green-50 dark:bg-green-500/10
                            border border-green-200 dark:border-green-500/30">
                  <div class="w-2 h-2 rounded-full bg-green-500 flex-shrink-0"></div>
                  <p class="text-xs font-semibold text-green-700 dark:text-green-400">
                    {{this.selectedDate}} à {{this.selectedSlotTime}}
                  </p>
                </div>
                <p class="text-xs text-center text-gray-400 dark:text-gray-500">
                  Cliquez sur "Suivant" pour confirmer
                </p>
              </div>
            {{/if}}

          </div>
        </div>
      {{/if}}

    </div>
  {{/if}}

  {{!-- Actions Footer --}}
  <div class="flex-shrink-0 flex flex-col sm:flex-row justify-between items-center
              gap-3 px-6 py-4 border-t
              bg-white dark:bg-gray-900
              border-gray-200 dark:border-gray-700">
    <div class="flex gap-2 w-full sm:w-auto">
      <button class="btn btn-secondary font-medium" {{on "click" @onPrevious}}>← Retour</button>
      <button class="btn btn-secondary font-medium" {{on "click" @onCancel}}>✕ Annuler</button>
    </div>
    <button
      class="btn btn-primary w-full sm:w-auto font-semibold
             disabled:opacity-40 disabled:cursor-not-allowed"
      disabled={{not this.isStep3Valid}}
      {{on "click" @onNext}}
    >
      Suivant →
    </button>
  </div>

</div>
