<div class="details-wrapper" ...attributes>
    <ContentPanel @title="Compte utilisateur" @open={{true}} @wrapperClass="bordered-top">
        <div class="grid grid-cols-2 gap-2 text-xs dark:text-gray-100">
            <div class="field-info-container md:col-span-3">
                <div class="field-name">Nom</div>
                <div class="field-value">{{n-a @resource.name}}</div>
            </div>
            <div class="field-info-container">
                <div class="field-name">Email</div>
                <ClickToCopy @value={{@resource.email}} class="field-value">{{n-a @resource.email}}</ClickToCopy>
            </div>
            <div class="field-info-container">
                <div class="field-name">Téléphone</div>
                <ClickToCopy @value={{@resource.phone}} class="field-value">{{n-a @resource.phone}}</ClickToCopy>
            </div>
        </div>
    </ContentPanel>

    <ContentPanel @title="Détails du conducteur" @open={{true}} @wrapperClass="bordered-top">
        <div class="grid grid-cols-2 gap-2 text-xs dark:text-gray-100">
            {{!-- <div class="field-info-container">
                <div class="field-name">ID</div>
                <ClickToCopy @value={{@resource.public_id}} class="field-value">{{n-a @resource.public_id}}</ClickToCopy>
            </div> --}}
            {{!-- <div class="field-info-container">
                <div class="field-name">ID interne</div>
                <div class="field-value">{{n-a @resource.internal_id}}</div>
            </div> --}}
            <div class="field-info-container">
                <div class="field-name">Numéro de permis</div>
                <div class="field-value">{{n-a @resource.drivers_license_number}}</div>
            </div>

            <div class="field-info-container">
                <div class="field-name">Date d'expiration du permis</div>
                <div class="field-value">{{#if @resource.drivers_license_expiry}}{{format-date @resource.drivers_license_expiry "dd MMM yyyy"}}{{else}}-{{/if}}</div>
            </div>

            {{!-- <div class="field-info-container">
                <div class="field-name">Fournisseur</div>
                <div class="field-value">{{n-a @resource.vendor_name}}</div>
            </div> --}}
            <div class="col-span-3"></div>
            <div class="field-info-container">
                <div class="field-name">Ville</div>
                <div class="field-value">{{n-a @resource.city}}</div>
            </div>
            <div class="field-info-container">
                <div class="field-name">Pays</div>
                <div class="field-value">
                    <CountryName @country={{@resource.country}} />
                </div>
            </div>
            {{!-- <div class="field-info-container md:col-span-3">
                <div class="field-name">Coordonnées</div>
                <div class="field-value">{{point-coordinates @resource.location}}</div>
            </div> --}}
        </div>
    </ContentPanel>

    <CustomField::Yield @subject={{@resource}} @viewMode={{true}} @wrapperClass="bordered-top" />

    {{!-- <RegistryYield @registry="fleet-ops:component:driver:details" as |RegistryComponent|>
        <RegistryComponent @resource={{@resource}} @controller={{@controller}} @permission={{get-write-permission @resource}} />
    </RegistryYield>

    <ContentPanel @title="Métadonnées" @open={{true}} @actionButtons={{this.metadataButtons}} @wrapperClass="bordered-top" @panelBodyWrapperClass={{unless (is-object-empty @resource.meta) "px-0i" ""}}>
        <MetadataViewer @metadata={{@resource.meta}} />
    </ContentPanel> --}}
</div>