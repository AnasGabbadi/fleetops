                    (mut @resource.carte_grise_date)}} @placeholder="DD-MM-YYYY"
                    class="filter-date-input w-full flex-1" />
            </InputGroup>
            <InputGroup @name="Date expiration carte grise">
                <DatePicker @value={{or (format-date-fns @resource.carte_grise_expiry "dd-MM-yyyy" ) null}}
                    @onChange={{fn (mut @resource.carte_grise_expiry)}} @placeholder="DD-MM-YYYY"
                    class="filter-date-input w-full flex-1" />
            </InputGroup>

        </div>
    </ContentPanel>

