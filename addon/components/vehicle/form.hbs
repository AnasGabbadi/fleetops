                    (mut @resource.vignette_date)}} @placeholder="DD-MM-YYYY" class="filter-date-input w-full flex-1" />
            </InputGroup>
            <InputGroup @name="Date expiration vignette">
                <DatePicker @value={{or (format-date-fns @resource.vignette_expiry "dd-MM-yyyy" ) null}} @onChange={{fn
                    (mut @resource.vignette_expiry)}} @placeholder="DD-MM-YYYY"
