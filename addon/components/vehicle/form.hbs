<div class="form-wrapper" ...attributes>
    {{! DETAILS / IDENTIFICATION }}
    <ContentPanel @title="Détails" @open={{true}} @wrapperClass="bordered-top">
        <div class="flex flex-row space-x-3 mb-3">
            <div class="flex items-center justify-start rounded-full">
                <Image src={{@resource.photo_url}} @fallbackSrc={{config "defaultValues.vehicleImage" }}
                    alt={{@resource.name}} height="48" width="48" class="h-14 w-14 rounded-full shadow-sm" />
                <Attach::Tooltip @class="clean" @animation="scale" @placement="top">
                    <InputInfo @text="Télécharger une nouvelle photo" />
                </Attach::Tooltip>
            </div>
            <div>
                <UploadButton @name="Photos" @accept="image/*" @onFileAdded={{perform this.handlePhotoUpload}}
                    @icon="upload" @size="xs" @buttonText="Télécharger une image" @disabled={{cannot-write
                    @resource}} />
                <div class="px-1">
                    <span class="text-gray-300 dark:text-gray-600 text-xs">Formats supportés : JPG, PNG, GIF</span>
                </div>
            </div>
        </div>

        <div class="grid grid-cols-1 gap-2 lg:grid-cols-2 lg:gap-2 no-input-group-padding text-xs">
            {{! Vehicle Identification }}
            <div class="col-span-1 lg:col-span-2 text-[11px] uppercase tracking-wide text-gray-500 font-semibold mt-1">
                Identification du véhicule
            </div>

            {{!-- <InputGroup @name="Nom / Désignation">
                <Input @value={{@resource.name}} @type="text" class="w-full form-input" placeholder="Nom du véhicule"
                    disabled={{cannot-write @resource}} />
            </InputGroup> --}}

            {{!-- <InputGroup @name={{t "common.internal-id" }}>
                <Input @value={{@resource.internal_id}} @type="text" class="w-full form-input"
                    placeholder={{t "common.internal-id" }} disabled={{cannot-write @resource}} />
            </InputGroup> --}}

            <InputGroup @name="Immatriculation">
                <Input @value={{@resource.plate_number}} @type="text" class="w-full form-input"
                    placeholder="Ex: 12345-A-1" disabled={{cannot-write @resource}} />
            </InputGroup>

            <InputGroup @name="Numéro de châssis (VIN)">
                <Input @value={{@resource.vin}} @type="text" class="w-full form-input" placeholder="Numéro de châssis"
                    disabled={{cannot-write @resource}} />
            </InputGroup>

            {{!-- <InputGroup @name={{t "vehicle.fields.make" }}>
                <Input @value={{@resource.make}} @type="text" class="w-full form-input"
                    placeholder={{t "vehicle.fields.vehicle-make" }} disabled={{cannot-write @resource}} />
            </InputGroup> --}}
            
            {{! ← MODIFIÉ: Marque dynamique depuis Kounhany }}
            <InputGroup @name="Marque *">
                <div class="fleetbase-model-select fleetbase-power-select ember-model-select">
                    <PowerSelect
                        @options={{this.brands}}
                        @selected={{this.selectedBrand}}
                        @onChange={{this.onBrandChange}}
                        @searchField="manuName"
                        @placeholder="Sélectionner une marque"
                        @triggerClass="form-select form-input"
                        @disabled={{cannot-write @resource}}
                        as |brand|>
                        {{brand.manuName}}
                    </PowerSelect>
                </div>
            </InputGroup>

            {{!-- <InputGroup @name={{t "vehicle.fields.model" }}>
                <Input @value={{@resource.model}} @type="text" class="w-full form-input"
                    placeholder={{t "vehicle.fields.vehicle-model" }} disabled={{cannot-write @resource}} />
            </InputGroup> --}}
            
            {{! ← MODIFIÉ: Modèle dynamique depuis Kounhany }}
            <InputGroup @name="Modèle *">
                <div class="fleetbase-model-select fleetbase-power-select ember-model-select">
                    <PowerSelect
                        @options={{this.models}}
                        @selected={{this.selectedModel}}
                        @onChange={{this.onModelChange}}
                        @searchField="modelname"
                        @placeholder={{if this.selectedBrand "Sélectionner un modèle" "Sélectionnez d'abord une marque"}}
                        @triggerClass="form-select form-input"
                        @disabled={{or (cannot-write @resource) (not this.selectedBrand)}}
                        as |model|>
                        {{model.modelname}}
                    </PowerSelect>
                </div>
            </InputGroup>

            <InputGroup @name="Année">
                <Input @value={{@resource.year}} @type="text" class="w-full form-input" placeholder="Ex: 2024"
                    disabled={{cannot-write @resource}} />
            </InputGroup>

            {{! ← MODIFIÉ: Version dynamique depuis Kounhany (PowerSelect au lieu de Input) }}
            <InputGroup @name="Version *">
                <div class="fleetbase-model-select fleetbase-power-select ember-model-select">
                    <PowerSelect
                        @options={{this.versions}}
                        @selected={{this.selectedVersion}}
                        @onChange={{this.onVersionChange}}
                        @searchField="carName"
                        @placeholder={{if this.selectedModel "Sélectionner une version" "Sélectionnez d'abord un modèle"}}
                        @triggerClass="form-select form-input"
                        @disabled={{or (cannot-write @resource) (not this.selectedModel)}}
                        as |version|>
                        <div>
                            <div class="font-semibold">{{version.carName}}</div>
                            <div class="text-xs text-gray-500">{{version.carDescription}}</div>
                        </div>
                    </PowerSelect>
                </div>
            </InputGroup>

            {{!--
            <InputGroup @value={{@resource.trim}} @name="Trim" @placeholder="Trim" /> --}}
            <InputGroup @value={{@resource.color}} @name="Couleur" @placeholder="Couleur du véhicule" />
            <InputGroup @value={{@resource.serial_number}} @name="Numéro de série" @placeholder="Numéro de série" />
            {{!--
            <InputGroup @value={{@resource.class}} @name="Class" @placeholder="Class" /> --}}

            {{! Assignment & Status }}
            <div class="col-span-1 lg:col-span-2 text-[11px] uppercase tracking-wide text-gray-500 font-semibold mt-3">
                Affectation & Statut
            </div>

            <InputGroup @name="Flotte">
                <ModelSelect @modelName="fleet" @selectedModel={{@resource.fleet}}
                    @placeholder="Sélectionner une flotte" @triggerClass="form-select form-input"
                    @infiniteScroll={{false}} @renderInPlace={{true}} @onChange={{fn (mut @resource.fleet)}}
                    @onChangeId={{fn (mut @resource.fleet_uuid)}}
                    @disabled={{cannot-write @resource}} as |model|>
                    {{model.name}}
                </ModelSelect>
            </InputGroup>

            <InputGroup @name="Conducteur assigné">
                <ModelSelect @modelName="driver" @selectedModel={{@resource.driver}}
                    @placeholder="Sélectionner un conducteur" @triggerClass="form-select form-input"
                    @infiniteScroll={{false}} @renderInPlace={{true}} @onChange={{this.assignDriver}}
                    @permission="fleet-ops assign-driver-for vehicle" as |model|>
                    {{model.name}}
                </ModelSelect>
            </InputGroup>

            <InputGroup @name="Statut">
                <div class="fleetbase-model-select fleetbase-power-select ember-model-select">
                    <PowerSelect @options={{get-fleet-ops-options "vehicleStatuses" }} @selected={{find-by "value"
                        @resource.status (get-fleet-ops-options "vehicleStatuses" )}} @onChange={{set-model-attr
                        @resource "status" }} @placeholder="Statut du véhicule" @triggerClass="form-select form-input"
                        @disabled={{cannot-write @resource}} as |option|>
                        <div class="text-sm">
                            <div class="font-semibold normalize-in-trigger">{{option.label}}</div>
                            <div class="hide-from-trigger">{{option.description}}</div>
                        </div>
                    </PowerSelect>
                </div>
            </InputGroup>

            {{!--
            <InputGroup @value={{@resource.call_sign}} @name="Call Sign" @placeholder="Call Sign" /> --}}

            {{! Location }}
            {{!-- <div
                class="col-span-1 lg:col-span-2 text-[11px] uppercase tracking-wide text-gray-500 font-semibold mt-3">
                Location
            </div>

            <InputGroup @name={{t "common.coordinates" }} @wrapperClass="col-span-2">
                <ModelCoordinatesInput @model={{@resource}} @disabled={{cannot-write @resource}}
                    @autocomplete="location" />
            </InputGroup> --}}
        </div>

        <RegistryYield @registry="fleet-ops:component:vehicle:form:details" as |RegistryComponent|>
            <RegistryComponent @resource={{@resource}} @controller={{this.controller}}
                @permission={{get-write-permission @resource}} />
        </RegistryYield>
    </ContentPanel>

    {{! KILOMÉTRAGE & CARBURANT }}
    <ContentPanel @title="Kilométrage & Carburant" @open={{true}} @wrapperClass="bordered-top">
        <div class="grid grid-cols-1 gap-2 lg:grid-cols-2 lg:gap-2 no-input-group-padding text-xs">
            <div class="col-span-1 lg:col-span-2 text-[11px] uppercase tracking-wide text-gray-500 font-semibold mt-1">
                Kilométrage & Unités
            </div>

            <InputGroup @name="Système de mesure">
                <div class="fleetbase-model-select fleetbase-power-select ember-model-select">
                    <PowerSelect @options={{get-fleet-ops-options "measurementSystems" }} @selected={{find-by "value"
                        @resource.measurement_system (get-fleet-ops-options "measurementSystems" )}}
                        @onChange={{set-model-attr @resource "measurement_system" }}
                        @placeholder="Sélectionner le système" @triggerClass="form-select form-input"
                        @disabled={{cannot-write @resource}} as |option|>
                        <div class="text-sm">
                            <div class="font-semibold normalize-in-trigger">{{option.label}}</div>
                            <div class="hide-from-trigger">{{option.description}}</div>
                        </div>
                    </PowerSelect>
                </div>
            </InputGroup>

            <InputGroup @name="Unité volume carburant">
                <div class="fleetbase-model-select fleetbase-power-select ember-model-select">
                    <PowerSelect @options={{get-fleet-ops-options "fuelVolumeUnits" }} @selected={{find-by "value"
                        @resource.fuel_volume_unit (get-fleet-ops-options "fuelVolumeUnits" )}}
                        @onChange={{set-model-attr @resource "fuel_volume_unit" }} @placeholder="Sélectionner l'unité"
                        @triggerClass="form-select form-input" @disabled={{cannot-write @resource}} as |option|>
                        <div class="text-sm">
                            <div class="font-semibold normalize-in-trigger">{{option.label}}</div>
                            <div class="hide-from-trigger">{{option.description}}</div>
                        </div>
                    </PowerSelect>
                </div>
            </InputGroup>

            <div class="col-span-1 lg:col-span-2 text-[11px] uppercase tracking-wide text-gray-500 font-semibold mt-3">
                Kilométrage & Usage
            </div>

            <InputGroup @value={{@resource.odometer}} @name={{concat "Kilométrage actuel (" @resource.odometer_unit ")"
                }} @type="number" @placeholder="Kilométrage actuel" />

            <InputGroup @name="Unité kilométrage">
                <div class="fleetbase-model-select fleetbase-power-select ember-model-select">
                    <PowerSelect @options={{get-fleet-ops-options "odometerUnits" }} @selected={{find-by "value"
                        @resource.odometer_unit (get-fleet-ops-options "odometerUnits" )}} @onChange={{set-model-attr
                        @resource "odometer_unit" }} @placeholder="Sélectionner l'unité"
                        @triggerClass="form-select form-input" @disabled={{cannot-write @resource}} as |option|>
                        <div class="text-sm">
                            <div class="font-semibold normalize-in-trigger">{{option.label}}</div>
                            <div class="hide-from-trigger">{{option.description}}</div>
                        </div>
                    </PowerSelect>
                </div>
            </InputGroup>

            <InputGroup @value={{@resource.odometer_at_purchase}} @name="Kilométrage à l'achat" @type="number"
                @placeholder="Kilométrage lors de l'achat" />
        </div>
    </ContentPanel>

    {{! TYPE & CARBURANT }}
