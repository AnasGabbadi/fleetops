            </InputGroup>

            <div class="col-span-1 lg:col-span-2 text-[11px] uppercase tracking-wide text-gray-500 font-semibold mt-3">
                Visite Technique
            </div>
            <InputGroup @name="Date visite technique">
                <DatePicker @value={{or (format-date-fns @resource.visite_technique_date "dd-MM-yyyy" ) null}}
                    @onChange={{fn (mut @resource.visite_technique_date)}} @placeholder="DD-MM-YYYY"
                    class="filter-date-input w-full flex-1" />
            </InputGroup>
            <InputGroup @name="Date expiration visite technique">
                <DatePicker @value={{or (format-date-fns @resource.visite_technique_expiry "dd-MM-yyyy" ) null}}
                    @onChange={{fn (mut @resource.visite_technique_expiry)}} @placeholder="DD-MM-YYYY"
                    class="filter-date-input w-full flex-1" />
            </InputGroup>

            <div class="col-span-1 lg:col-span-2 text-[11px] uppercase tracking-wide text-gray-500 font-semibold mt-3">
