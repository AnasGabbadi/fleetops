<Modal::Default @modalIsOpened={{@modalIsOpened}} @options={{@options}} @confirm={{@onConfirm}} @decline={{@onDecline}}>
    <div class="modal-body-container pt-0i text-gray-900 dark:text-white">
        <InputGroup @name="Nom de l'organisation *">
            <Input @value={{@options.organization_name}} @type="text" class="w-full form-input"
                placeholder="Ex: Entreprise ABC" />
        </InputGroup>
        <InputGroup @name="Nom de l'administrateur *">
            <Input @value={{@options.name}} @type="text" class="w-full form-input" placeholder="Nom complet" />
        </InputGroup>
        <InputGroup @name="Email *">
            <Input @value={{@options.email}} @type="email" class="w-full form-input"
                placeholder="admin@entreprise.com" />
        </InputGroup>
        <InputGroup @name="Téléphone">
            <PhoneInput @value={{@options.phone}} @onInput={{fn (mut @options.phone)}} class="form-input w-full" />
        </InputGroup>
        <InputGroup @name="Mot de passe *">
            <div class="relative w-full">
                <Input @value={{@options.password}} @type={{if @options.showPassword "text" "password" }}
                    class="w-full form-input pr-10" placeholder="Mot de passe" />
                <button type="button"
                    class="absolute inset-y-0 right-0 pr-3 flex items-center text-gray-500 hover:text-gray-700 dark:text-gray-400"
                    {{on "click" (fn (mut @options.showPassword) (not @options.showPassword))}}>
                    <FaIcon @icon={{if @options.showPassword "eye-slash" "eye" }} />
                </button>
            </div>
        </InputGroup>

        <InputGroup @name="Confirmer le mot de passe *">
            <div class="relative w-full">
                <Input @value={{@options.password_confirm}} @type="password" class="w-full form-input pr-10"
                    placeholder="Confirmer le mot de passe" />
            </div>
        </InputGroup>
    </div>
</Modal::Default>